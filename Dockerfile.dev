# ============================================================
# AetherCompass — Remote Development Environment
# VS Code in the browser (code-server) + Python 3.11 + Node 22
# ============================================================

FROM codercom/code-server:latest

USER root

# ── System dependencies ──────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    build-essential \
    curl \
    git \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 LTS ──────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Python alias (Debian uses python3) ───────────────────────
RUN ln -sf /usr/bin/python3 /usr/bin/python

# ── Install backend Python dependencies globally ────────────
COPY backend/requirements.txt /tmp/requirements.txt
RUN pip3 install --no-cache-dir --break-system-packages -r /tmp/requirements.txt \
    && rm /tmp/requirements.txt

# ── Switch back to non-root coder user ──────────────────────
USER 1000

# ── Pre-install VS Code Extensions ──────────────────────────
RUN code-server --install-extension ms-python.python \
    && code-server --install-extension dsznajder.es7-react-js-snippets \
    && code-server --install-extension bradlc.vscode-tailwindcss \
    && code-server --install-extension esbenp.prettier-vscode

# ── Default code-server settings ────────────────────────────
RUN mkdir -p /home/coder/.local/share/code-server/User \
    && echo '{\
  "editor.fontSize": 15,\
  "editor.fontFamily": "\"Cascadia Code\", \"Fira Code\", Consolas, monospace",\
  "editor.formatOnSave": true,\
  "editor.minimap.enabled": false,\
  "editor.bracketPairColorization.enabled": true,\
  "editor.guides.bracketPairs": true,\
  "editor.tabSize": 2,\
  "workbench.colorTheme": "Default Dark Modern",\
  "terminal.integrated.defaultProfile.linux": "bash",\
  "files.autoSave": "afterDelay",\
  "files.autoSaveDelay": 1000,\
  "python.defaultInterpreterPath": "/usr/bin/python3",\
  "[python]": {\
    "editor.tabSize": 4\
  }\
}' > /home/coder/.local/share/code-server/User/settings.json

# ── Workspace & Ports ───────────────────────────────────────
WORKDIR /workspace
EXPOSE 8443

ENTRYPOINT ["dumb-init", "code-server", "--bind-addr", "0.0.0.0:8443", "--auth", "password", "/workspace"]
